import { report } from "Study"

import Event from "@/Event"
import State from "@/State"
import Transition from "@/Transition"



report(State.terminal, "State.terminal", [#["pen", State.State("pen", [])]])
report(State.id, "State.id", [#[State.terminal("pen"), "pen"]])


report(
  State.routes,
  "State.routes",
  [
    #[
      State.create("pen", [Transition.Route.create(Event.create("click"), "extended")]),
      [Transition.Route.create(Event.create("click"), "extended")],
    ],
  ],
)
