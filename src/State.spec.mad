import { report } from "Study"

import Event from "@/Event"
import State from "@/State"
import Transition from "@/Transition"



report(State.create, "State.create", [#["pen", State.State("pen", [])]])
report(State.id, "State.id", [#[State.create("pen"), "pen"]])
report(
  State.transitions,
  "State.transitions",
  [
    #[
      State.withTransitions("pen", [Transition.create(Event.create("click"), "extended")]),
      [Transition.create(Event.create("click"), "extended")],
    ],
  ],
)
