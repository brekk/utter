import type { Maybe } from "Maybe"

import type { Machine } from "@/Machine"

import { Just, Nothing, fromMaybe } from "Maybe"

import Blueprint from "@/Blueprint"
import { log } from "@/Log"
import Machine from "@/Machine"



export type Interpreter a pay ctx
  = Interpreter(Machine a pay ctx, Interpreter a pay ctx -> {}, Maybe ctx)

export create = (machine, run) => where(machine) {
  Machine.Machine(_, _, _, ctx) =>
    Interpreter(machine, run, Just(ctx))
}

export alias TalkbackStructure a b c = {
  latest :: {} -> Machine a b c,
  send :: String -> Maybe b -> {},
}
export type Talkback a b c = Silence | Talkback(TalkbackStructure a b c)

export control = where {
  Interpreter(machine, run, init) =>
    where(Blueprint.fromMachine(machine, init)) {
      Blueprint.Blueprint({ destinations, isEvent, isState }) =>
        do {
          log.interpreter("OUT", destinations)

          current = machine
          send = (e, payload) => {
            if (isEvent(e)) do {
              log.interpreter("valid event", e)
            }
          }
          latest = () => current
          return Talkback({ send, latest })
        }

      _ =>
        Silence
    }
}
