import type { State } from "@/State"

import List from "List"

import { ERRORS, ERROR_CODES } from "@/Error"
import { log, say } from "@/Log"



// logCreated = say($, "created!", $)


export type Machine a p x = Machine(a, List (State a p x), x)

export create = Machine

export value = where {
  Machine(a, _, _) =>
    a
}
export states = where {
  Machine(_, s, _) =>
    s
}
export context = where {
  Machine(_, _, c) =>
    c
}
