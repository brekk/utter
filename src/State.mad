import type { Transitions } from "@/Transition"



export type State a b c = State(b, Transitions a b c)

export id = where {
  State(i, _) =>
    i
}
export transitions = where {
  State(_, t) =>
    t
}

create :: b -> Transitions a b c -> State a b c
export create = State

// final is a reserved word?
terminal :: b -> State a b c
export terminal = create($, [])
